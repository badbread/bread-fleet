# Secrets: never commit
fleet-server/.env
fleet-server/cloudflared/*.json
fleet-server/cloudflared/cert.pem
compliance-troubleshooter/.env
security-dashboard/.env
portal/.env

# TLS material for the local-HTTPS deployment shape
fleet-server/tls/*.crt
fleet-server/tls/*.key
fleet-server/tls/*.pem

# Runtime data: bind-mounted service state
fleet-server/data/

# Node dependencies (built inside Docker, not committed)
node_modules/

# Editor / OS cruft
.DS_Store
Thumbs.db
*.swp
.vscode/
.idea/

# Claude Code and oh-my-claudecode session state: not part of the project
.claude/
.omc/

# macOS resource forks on NAS SMB shares
.AppleDouble
._*

# Backup files
*.bak
*.orig
*~
__pycache__/
