# ============================================================================
# Compliance Troubleshooter runtime configuration. Copy to .env on the host
# running the stack. Never commit the populated .env.
# ============================================================================

# ---- Fleet API connection --------------------------------------------------
# The Fleet REST API URL the backend uses to fetch host and policy data.
# For a local deployment, this is the Docker host's IP and port. The
# backend NEVER talks to Fleet from a browser, only from the FastAPI
# process, so a non-public URL is fine.
FLEET_API_URL=http://10.0.0.10:8080

# Fleet API token for the troubleshooter's service account. Generate via
# the Fleet UI: Settings -> Users -> Create user with Admin role and copy
# the token from the user-creation modal.
#
# At scale this is a Fleet API-only user (Premium feature). For Fleet Free,
# use a regular admin user's session token from ~/.fleet/config or pull it
# from the API directly.
FLEET_API_TOKEN=

# ---- Claude API ------------------------------------------------------------
# Anthropic API key for the translation layer. If unset, the backend uses
# the static fallback dict in src/translator.py which covers the 12 CIS
# policies in gitops/default.yml.
ANTHROPIC_API_KEY=

# Claude model. Default is the current Sonnet generation. Override if you
# want to test against a different model.
ANTHROPIC_MODEL=claude-sonnet-4-5

# ---- Backend ---------------------------------------------------------------
# Bind address inside the container. The Compose stack maps this to
# 127.0.0.1:8088 on the host by default.
BACKEND_BIND=0.0.0.0:8088

# Audit log location inside the container. Mounted to a host volume by
# the Compose file.
AUDIT_LOG_PATH=/data/troubleshooter.jsonl

# CORS origin the backend allows for the frontend. In dev this is the
# Vite dev server; in the Compose stack this is the nginx-served frontend.
CORS_ORIGIN=http://localhost:5173

# ---- Frontend --------------------------------------------------------------
# Backend URL the frontend talks to. Browser-accessible.
VITE_BACKEND_URL=http://localhost:8088
