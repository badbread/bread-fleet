# Portal deployment environment variables.
# Copy to .env and fill in the values before running docker compose up.

# Fleet API connection (for the Compliance Troubleshooter backend).
# The troubleshooter is the only module that talks to the real Fleet
# instance. The Security Posture Dashboard uses synthetic data.
FLEET_API_URL=https://fleet.lan:8080
FLEET_API_TOKEN=

# Claude API key (for the Compliance Troubleshooter's plain-English
# translation of policy failures). Optional: if blank, the translator
# falls back to static mappings.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# Notion integration (for Compliance Troubleshooter live sync).
# Created by notion-sync/seed.py. The troubleshooter pushes new entries
# to this database in real time on every compliance check.
NOTION_API_TOKEN=
NOTION_DATABASE_ID=
