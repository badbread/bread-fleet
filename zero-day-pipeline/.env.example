# Zero-Day Response Pipeline environment variables.
# Copy to .env and fill in the values before running docker compose up.

# Fleet API connection (for deploying generated policies).
FLEET_API_URL=https://fleet.lan:8080
FLEET_API_TOKEN=

# Claude API key (for AI-assisted mapping of unknown products).
# Optional: if blank, the pipeline uses only the curated registry.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
