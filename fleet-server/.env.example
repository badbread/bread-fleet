# ============================================================================
# Fleet stack configuration: copy to .env and fill in the blanks.
# `.env` is gitignored. `.env.example` is the committed template.
# ============================================================================

# ---- Fleet version ---------------------------------------------------------
# Pin to an exact tag so `docker compose pull` doesn't silently upgrade.
# Check https://github.com/fleetdm/fleet/releases for current stable.
FLEET_VERSION=v4.70.0

# ---- MySQL credentials -----------------------------------------------------
# Root password is only used during MySQL's first-boot bootstrap.
# Generate strong values:  openssl rand -base64 32
MYSQL_ROOT_PASSWORD=CHANGEME_root_password_here
MYSQL_DATABASE=fleet
MYSQL_USER=fleet
MYSQL_PASSWORD=CHANGEME_fleet_user_password_here

# ---- Fleet auth ------------------------------------------------------------
# JWT signing key for admin session tokens. Must be at least 32 characters.
# Generate:  openssl rand -base64 48
FLEET_JWT_KEY=CHANGEME_at_least_32_chars_random_string_here

# ---- Public URL ------------------------------------------------------------
# Must exactly match the hostname served by the Cloudflare Tunnel.
# Used by Fleet to build enrollment URLs, email links, and the osquery
# TLS endpoint that agents connect to.
FLEET_SERVER_URL=https://fleet.example.com

# ---- Cloudflare Tunnel token -----------------------------------------------
# Created in the Cloudflare Zero Trust dashboard:
#   Networks -> Tunnels -> Create a tunnel -> Docker -> copy the token
# from the `--token <LONG_STRING>` value in the suggested docker run command.
CLOUDFLARED_TOKEN=CHANGEME_cloudflare_tunnel_token_here
